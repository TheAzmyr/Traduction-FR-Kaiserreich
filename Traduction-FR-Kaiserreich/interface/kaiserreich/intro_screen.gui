	containerWindowType = {
		name = kr_intro_screen_tab_1_container
		position = { x = 0 y = 436 }
		size = { width = 720 height = 400 }
		margin = { left = 16 right = 16 }
		clipping = yes

		## backdrop texticon scripted loc textbox
		containerWindowType = {
			name = "kr_intro_screen_tab_1_background"
			size = { width = 172 height = 392 }

			background = { quadTextureSprite = "GFX_tiled_paper_bg2" }

			iconType = {
				name = "KR_welcome_splash_tab_1_background_icon"
				spriteType = "GFX_KR_default_intro"
				position = { x = 2 y = 2 }
			}
		}

		## Options
		@container_pos_x = 2

		@container_pos_slot_0_y = 22
		@container_pos_slot_1_y = 44
		@container_pos_slot_2_y = 66
		@container_pos_slot_3_y = 88
		@container_pos_slot_4_y = 110

		@checkbox_pos_x = 0
		@checkbox_pos_y = 0

		@label_pos_x = 30
		@label_pos_y = 3
		@label_width = 150

		containerWindowType = {
			name = "kr_options_container"
			position = { x = 0 y = 256 }

			instantTextboxType = {
				name = "title"
				position = { x = 0 y = 0 }
				textureFile = ""
				font = "hoi_24header"
				borderSize = { x = 0 y = 0 }
				text = "kr_options_title"
				maxWidth = 172 #== (window size - 10)
				format = center
			}

			## Custom Achievements toggle
			containerWindowType = {
				name = "custom_achievements_container"
				position = { x = @container_pos_x y = @container_pos_slot_0_y }
				Orientation = upper_left

				buttonType = {
					name = "custom_achievements_button"
					position = { x = @checkbox_pos_x y = @checkbox_pos_y }
					quadTextureSprite = "GFX_generic_checkbox3"
					clicksound = decisions_ui_button
					pdx_tooltip = custom_achievements_tooltip
				}

				instantTextboxType = {
					name = "custom_achievements_text"
					position = { x = @label_pos_x y = @label_pos_y }
					textureFile = ""
					font = "hoi_16mbs"
					borderSize = { x = 0 y = 0 }
					text = "custom_achievements_text"
					maxWidth = @label_width
					format = left
				}
			}

			## State/VP Renames toggle
			containerWindowType = {
				name = "rename_container"
				position = { x = @container_pos_x y = @container_pos_slot_1_y }
				Orientation = upper_left

				buttonType = {
					name = "rename_button"
					position = { x = @checkbox_pos_x y = @checkbox_pos_y }
					quadTextureSprite = "GFX_generic_checkbox3"
					clicksound = decisions_ui_button
					pdx_tooltip = rename_tooltip
				}

				instantTextboxType = {
					name = "rename_text"
					position = { x = @label_pos_x y = @label_pos_y }
					textureFile = ""
					font = "hoi_16mbs"
					borderSize = { x = 0 y = 0 }
					text = "rename_text"
					maxWidth = @label_width
					format = left
				}
			}

			## Sound Events toggle
			containerWindowType = {
				name = "sound_events_container"
				position = { x = @container_pos_x y = @container_pos_slot_2_y }
