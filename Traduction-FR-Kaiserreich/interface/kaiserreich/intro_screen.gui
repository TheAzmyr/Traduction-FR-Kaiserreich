guiTypes = {
	containerWindowType = {
		name = "kr_intro_screen_button_container"
		position = { x = -131 y = 62 }
		orientation = upper_right

		buttonType = {
			name = "kr_intro_screen_button"
			position = { x = 0 y = 0 }
			quadTextureSprite = "GFX_kr_intro_screen_icon"
			clicksound = click_ok
			oversound = ui_menu_over
			pdx_tooltip = kr_intro_screen_button_title
			pdx_tooltip_delayed = kr_intro_screen_button_tooltip
			shortcut = "ctrl+i"
		}
	}

	containerWindowType = {
		name = "kr_intro_screen_container"
